msgstr "Pengguna ini tidak terhubung ke Jetpack. Hubungkan pengguna ke Jetpack sebelum mengonfigurasi pemberitahuan Monitor."

#: src/abilities/class-monitor-abilities.php:253
msgid "The Monitor module is not active. Activate it before configuring notifications."
msgstr "Modul monitor tidak aktif. Aktifkan sebelum mengonfigurasi pemberitahuan."

#: src/abilities/class-monitor-abilities.php:246
msgid "The enabled parameter must be a boolean. Strings like \"true\" / \"false\" are not accepted."
msgstr "Parameter yang diaktifkan harus berupa boolean. String seperti \"benar\" / \"salah\" tidak diterima."

#: src/abilities/class-monitor-abilities.php:240
msgid "A desired enabled state (boolean) is required."
msgstr "Diperlukan status aktif yang diinginkan (boolean)."

#: src/abilities/class-monitor-abilities.php:202
#: src/abilities/class-monitor-abilities.php:211
